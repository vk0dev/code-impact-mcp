{
  "name": "@vk0/code-impact-mcp",
  "version": "1.1.1",
  "mcpName": "io.github.vk0dev/code-impact-mcp",
  "description": "Lightweight pre-commit safety gate for AI agents. Answers 'is this change safe?' with PASS/WARN/BLOCK verdict in seconds. Zero setup, no database.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./graph": {
      "types": "./dist/graph.d.ts",
      "default": "./dist/graph.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "code-impact-mcp": "./dist/cli.js"
  },
  "scripts": {
    "build": "rm -rf dist && tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "smoke": "npm run build && node scripts/dogfood_smoke.mjs",
    "release-check": "node scripts/release-check.mjs",
    "version-sync": "node scripts/version-sync.mjs"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "dependency-graph",
    "impact-analysis",
    "blast-radius",
    "typescript",
    "javascript",
    "code-analysis",
    "claude",
    "claude-code",
    "anthropic",
    "ai-agent",
    "developer-tools",
    "local-first",
    "refactoring",
    "static-analysis"
  ],
  "author": "vk0.dev",
  "license": "MIT",
  "homepage": "https://vk0dev.github.io/code-impact-mcp",
  "repository": {
    "type": "git",
    "url": "https://github.com/vk0dev/code-impact-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/vk0dev/code-impact-mcp/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "ts-morph": "^28.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
