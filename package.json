{
  "name": "@vk0/code-impact-mcp",
  "version": "0.1.0",
  "description": "Impact analysis and blast radius for agent-driven code changes. Analyzes dependency graphs to predict what breaks before you commit.",
  "type": "module",
  "main": "dist/server.js",
  "bin": { "code-impact-mcp": "./dist/cli.js" },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "smoke": "tsx scripts/test-mcp-client.ts"
  },
  "keywords": ["mcp", "mcp-server", "claude-code", "ai-agent"],
  "author": "vk0.dev",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^5.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
