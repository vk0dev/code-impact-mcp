{
  "name": "@vk0/code-impact-mcp",
  "version": "0.1.1",
  "mcpName": "io.github.vk0dev/code-impact-mcp",
  "description": "Dependency graph, blast-radius analysis, and gate-style checks for local TypeScript and JavaScript repositories.",
  "type": "module",
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    },
    "./graph": {
      "types": "./dist/graph.d.ts",
      "default": "./dist/graph.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "code-impact-mcp": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "smoke": "tsx scripts/test-mcp-client.ts"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "dependency-graph",
    "impact-analysis",
    "blast-radius",
    "typescript"
  ],
  "author": "vk0.dev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vk0dev/code-impact-mcp.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^5.1.0",
    "ts-morph": "^27.0.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
